FROM rust:1.87

RUN apt-get update && apt-get install -y \
    build-essential \
    pkg-config \
    libssl-dev \
    # Windows クロスコンパイル用
    gcc-mingw-w64-x86-64 \
    g++-mingw-w64-x86-64 \
    # bindgen 用（libclang）
    llvm-dev \
    libclang-dev \
    clang \
    && rm -rf /var/lib/apt/lists/*

RUN rustup target add x86_64-pc-windows-gnu
